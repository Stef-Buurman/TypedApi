{
  "name": "typedapi-client-helpers",
  "version": "0.1.16",
  "description": "Reusable typed OpenAPI client helpers.",
  "keywords": [
    "typescript",
    "openapi",
    "swagger",
    "api-client",
    "typed-api",
    "typescript-api-client",
    "openapi-client",
    "swagger-client",
    "client-generator",
    "api-generator",
    "codegen",
    "type-safe",
    "type-safe-api",
    "fetch",
    "frontend",
    "api-wrapper",
    "generated-client",
    "swagger-typescript-api",
    "form-data",
    "multipart",
    "pagination",
    "filters",
    "sorting"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "bin",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stef-Buurman/TypedApi.git",
    "directory": "npm/typed-api-client"
  },
  "homepage": "https://github.com/Stef-Buurman/TypedApi/tree/main/npm/typed-api-client#readme",
  "config": {
    "apiOutput": "src/api",
    "typedApiDefaultFunctionsPath": "src/defaultApiFunctions",
    "typedApiDefaultSuccessHandler": "handleGoodResult",
    "typedApiDefaultErrorHandler": "handleErrors"
  },
  "bin": {
    "typedapi-generate": "bin/typedapi-generate.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "generate:api": "node ./scripts/generate-api-minimal.mjs"
  },
  "dependencies": {
    "swagger-typescript-api": "^13.2.16"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.8.3"
  }
}
