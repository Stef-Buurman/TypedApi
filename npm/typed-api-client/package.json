{
  "name": "typedapi-client-helpers",
  "version": "0.1.2",
  "description": "Reusable typed OpenAPI client helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "bin",
    "README.md"
  ],
  "config": {
    "apiOutput": "src/api"
  },
  "bin": {
    "typedapi-generate": "bin/typedapi-generate.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "generate:api": "node ./scripts/generate-api-minimal.mjs",
    "clean:package": "powershell -NoProfile -Command \"Remove-Item -Force .\\*.tgz -ErrorAction SilentlyContinue\"",
    "pack:check": "npm run build && npm pack --dry-run",
    "pack:local": "npm run build && npm pack",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "publish:check": "npm whoami && npm run pack:check",
    "publish:patch": "npm run version:patch && npm run publish:check && npm publish",
    "publish:minor": "npm run version:minor && npm run publish:check && npm publish",
    "publish:major": "npm run version:major && npm run publish:check && npm publish"
  },
  "dependencies": {
    "prettier": "^3.8.3",
    "react-toastify": "^11.0.5",
    "swagger-typescript-api": "^13.2.16"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "5.8.3"
  }
}
